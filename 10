import numpy as np

try:
    n = int(input("Enter how many random numbers you want to generate: "))

    if n <= 0:
        print("Please enter a positive number.")
    else:
        arr = np.random.randint(10, 101, n)

        print("\nGenerated Array:")
        print(arr)

        print("\nMean:", np.mean(arr))
        print("Median:", np.median(arr))
        print("Standard Deviation:", np.std(arr))
        print("Minimum:", np.min(arr))
        print("Maximum:", np.max(arr))

        # Reshape if possible
        root = int(np.sqrt(n))

        if root * root == n:
            matrix = arr.reshape(root, root)

            print("\nReshaped Matrix:")
            print(matrix)

            print("\nRow-wise Sum:")
            print(np.sum(matrix, axis=1))
        else:
            print("\nReshaping into a square matrix is not possible.")

except ValueError:
    print("Invalid input! Please enter an integer.")
except Exception as e:
    print("Error:", e)